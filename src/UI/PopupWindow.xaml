<Window x:Class="QuickLaunch.UI.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True"
        Width="300"
        SizeToContent="Height">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ShortcutButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="8" Padding="5" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="3"
                              Opacity="0.5" BlurRadius="12"/>
        </Border.Effect>
        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="560"
                      HorizontalScrollBarVisibility="Disabled"
                      BorderThickness="0">
            <StackPanel x:Name="ContentPanel" Margin="0,4">
                <ItemsControl x:Name="ShortcutList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource ShortcutButton}"
                                    Tag="{Binding FullPath}"
                                    Click="ShortcutButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding Icon}"
                                           Width="{Binding IconSize}"
                                           Height="{Binding IconSize}"
                                           Margin="0,0,10,0"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="{Binding DisplayName}"
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               FontFamily="Segoe UI"
                                               Foreground="{DynamicResource ForegroundBrush}"
                                               Visibility="{Binding ShowLabel, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock x:Name="EmptyMessage"
                           Margin="12,8"
                           FontSize="13"
                           FontFamily="Segoe UI"
                           Foreground="{DynamicResource ForegroundBrush}"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
